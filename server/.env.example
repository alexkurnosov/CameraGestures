# Copy this file to .env and adjust values for your environment

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# Directory where uploaded examples and trained models are stored
# Use an absolute path when deploying to a VPS
DATA_DIR=data

# Minimum number of examples per gesture before auto-training triggers
AUTO_TRAIN_THRESHOLD=10

# Trainer backend: "rf_mlp" (Keras MLP on stat features) | "lstm" (Keras LSTM on full sequence)
TRAINER=rf_mlp

# How many past model versions to keep on disk
MAX_MODEL_VERSIONS=5
